    "resend": "6.17.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "supabase": "2.109.1",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
